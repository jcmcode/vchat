# Domain and TLS
DOMAIN=vchat.example.com
ACME_EMAIL=you@example.com

# TURN server credentials
TURN_USER=vchat
TURN_PASSWORD=<run deploy.sh to generate>

# Basic auth (bcrypt hash — run: docker run caddy:2-alpine caddy hash-password --plaintext 'yourpassword')
BASIC_AUTH_HASH=<run deploy.sh to generate>

# TURN config baked into the web build
VITE_TURN_URL=turn:vchat.example.com:3478
VITE_TURN_USER=vchat
VITE_TURN_CREDENTIAL=<same as TURN_PASSWORD>
